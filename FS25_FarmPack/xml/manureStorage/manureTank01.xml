        <i3dMapping id="clearArea3Width" node="0>1|2|0|0" />
        <i3dMapping id="clearArea3Height" node="0>1|2|0|1" />
		<i3dMapping id="clearArea4Start" node="0>1|3|0" />
        <i3dMapping id="clearArea4Width" node="0>1|3|0|0" />
        <i3dMapping id="clearArea4Height" node="0>1|3|0|1" />
		<i3dMapping id="clearArea5Start" node="0>1|4|0" />
        <i3dMapping id="clearArea5Width" node="0>1|4|0|0" />
        <i3dMapping id="clearArea5Height" node="0>1|4|0|1" />
		<i3dMapping id="clearArea6Start" node="0>1|5|0" />
        <i3dMapping id="clearArea6Width" node="0>1|5|0|0" />
