<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="silo" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_storeItem_manureTank01</name>
        <image>storeIcon/store_manureTank01.png</image>
        <functions>
            <function>$l10n_function_liquidManureTank</function>
        </functions>
        <price>25000</price>
        <dailyUpkeep>20</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>silos</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>silos</tab>
        </brush>

        <storeIconRendering>
            <settings cameraXRot="-25" advancedBoundingBox="true" />
        </storeIconRendering>
        <vertexBufferMemoryUsage>111616</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>27648</indexBufferMemoryUsage>
        <textureMemoryUsage>4194304</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>i3d/manureStorage/manureTank01.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testArea1Start" endNode="testArea1End" />
        </testAreas>

        <sounds>
            <place template="smallImp" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearArea1Start" widthNode="clearArea1Width" heightNode="clearArea1Height"/>
		<clearArea startNode="clearArea2Start" widthNode="clearArea2Width" heightNode="clearArea2Height"/>
		<clearArea startNode="clearArea3Start" widthNode="clearArea3Width" heightNode="clearArea3Height"/>
		<clearArea startNode="clearArea4Start" widthNode="clearArea4Width" heightNode="clearArea4Height"/>
		<clearArea startNode="clearArea5Start" widthNode="clearArea5Width" heightNode="clearArea5Height"/>
		<clearArea startNode="clearArea6Start" widthNode="clearArea6Width" heightNode="clearArea6Height"/>
		<clearArea startNode="clearArea7Start" widthNode="clearArea7Width" heightNode="clearArea7Height"/>
		<clearArea startNode="clearArea8Start" widthNode="clearArea8Width" heightNode="clearArea8Height"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="10" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="clearArea2Start" widthNode="clearArea2Width" heightNode="clearArea2Height" groundType="gravel"/>
            <levelArea startNode="clearArea3Start" widthNode="clearArea3Width" heightNode="clearArea3Height" groundType="gravel"/>
            <levelArea startNode="clearArea4Start" widthNode="clearArea4Width" heightNode="clearArea4Height" groundType="gravel"/>
            <levelArea startNode="clearArea5Start" widthNode="clearArea5Width" heightNode="clearArea5Height" groundType="gravel"/>
            <levelArea startNode="clearArea6Start" widthNode="clearArea6Width" heightNode="clearArea6Height" groundType="gravel"/>
            <levelArea startNode="clearArea7Start" widthNode="clearArea7Width" heightNode="clearArea7Height" groundType="gravel"/>
            <levelArea startNode="clearArea8Start" widthNode="clearArea8Width" heightNode="clearArea8Height" groundType="gravel"/>
            <levelArea startNode="clearArea1Start" widthNode="clearArea1Width" heightNode="clearArea1Height" groundType="asphalt"/>
        </levelAreas>
    </leveling>

    <indoorAreas/>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
        </updateAreas>
        <splines>
            <spline node="aiSpline" />
        </splines>
    </ai>

    <infoTrigger triggerNode="infoTrigger"/>

    <silo>
        <loadingStation node="loadingTrigger" supportsExtension="true" storageRadius="70">
            <loadTrigger triggerNode="loadingTrigger" fillLitersPerSecond="2000" dischargeNode="dischargeNode" fillTypes="LIQUIDMANURE DIGESTATE" aiNode="aiLoadingNode" />
        </loadingStation>

        <unloadingStation supportsExtension="true" storageRadius="50" >
            <unloadTrigger exactFillRootNode="exactFillRootNode" fillTypes="LIQUIDMANURE DIGESTATE" aiNode="aiLoadingNode"/>
        </unloadingStation>

        <storages>
            <storage node="storage" fillTypes="LIQUIDMANURE DIGESTATE" capacity="500000" supportsMultipleFillTypes="true" isExtension="true">
                <fillPlane fillType="LIQUIDMANURE" node="slurryPit_fillPlane" minY="0.147" maxY="0.848" />
            </storage>
        </storages>
    </silo>

    <hotspots>
        <hotspot type="LOADING" linkNode="mapPosition" teleportNode="teleportNode" />
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="markerLoading"   filename="$data/shared/assets/marker/markerIconLoad.i3d" />
        <triggerMarker node="markerUnloading" filename="$data/shared/assets/marker/markerIconUnload.i3d" />
    </triggerMarkers>

    <i3dMappings>
        <i3dMapping id="mapPosition" node="0>0|0" />
        <i3dMapping id="storage" node="0>0|1" />
        <i3dMapping id="slurryPit_fillPlane" node="0>0|1|0" />
        <i3dMapping id="loadingStation" node="0>0|2" />
        <i3dMapping id="loadingTrigger" node="0>0|2|0|0" />
        <i3dMapping id="dischargeNode" node="0>0|2|0|1" />
        <i3dMapping id="aiLoadingNode" node="0>0|2|1" />
        <i3dMapping id="aiSpline" node="0>0|2|2" />
        <i3dMapping id="unloadingStation" node="0>0|3" />
        <i3dMapping id="exactFillRootNode" node="0>0|3|0" />
        <i3dMapping id="infoTrigger" node="0>0|4" />
		
        <i3dMapping id="clearArea1Start" node="0>1|0" />
        <i3dMapping id="clearArea1Width" node="0>1|0|0" />
        <i3dMapping id="clearArea1Height" node="0>1|0|1" />
		<i3dMapping id="clearArea2Start" node="0>1|1|0" />
