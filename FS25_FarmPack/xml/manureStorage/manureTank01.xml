		<i3dMapping id="clearArea7Start" node="0>1|6|0" />
        <i3dMapping id="clearArea7Width" node="0>1|6|0|0" />
        <i3dMapping id="clearArea7Height" node="0>1|6|0|1" />
		<i3dMapping id="clearArea8Start" node="0>1|7|0" />
        <i3dMapping id="clearArea8Width" node="0>1|7|0|0" />
        <i3dMapping id="clearArea8Height" node="0>1|7|0|1" />
		
        <i3dMapping id="testArea1Start" node="0>2|0" />
        <i3dMapping id="testArea1End" node="0>2|0|0" />
        <i3dMapping id="tipOcclusionUpdateArea1Start" node="0>3|0" />
        <i3dMapping id="tipOcclusionUpdateArea1End" node="0>3|0|0" />
        <i3dMapping id="markerUnloading" node="0>4" />
        <i3dMapping id="markerLoading" node="0>5" />
        <i3dMapping id="collisionFillTower" node="0>6|1" />
        <i3dMapping id="teleportNode" node="0>7" />
