<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="objectStorage" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_storeItem_barnOldBaleStorage02</name>
        <functions>
            <function>$l10n_function_garage</function>
            <function>$l10n_function_objectStorage</function>
        </functions>
        <image>storeIcon/store_barnOld04.dds</image>
        <price>62000</price>
        <dailyUpkeep>15</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>storages</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>silos</tab>
        </brush>
        <vertexBufferMemoryUsage>396288</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>76544</indexBufferMemoryUsage>
        <textureMemoryUsage>5046272</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>i3d/objectStorage/barnOldBaleStorage02.i3d</filename>
        <boughtWithFarmland>true</boughtWithFarmland>
        <canBeRenamed>true</canBeRenamed>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <testAreas>
            <testArea startNode="testAreaStart01" endNode="testAreaEnd01" />
        </testAreas>
        <sounds>
            <place template="medImp" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart01" widthNode="clearAreaWidth01" heightNode="clearAreaHeight01"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart01" widthNode="levelAreaWidth01" heightNode="levelAreaHeight01" groundType="asphalt"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart01" widthNode="indoorAreaWidth01" heightNode="indoorAreaHeight01"/>
    </indoorAreas>

    <triggerMarkers>
        <triggerMarker node="warningStripes" />
        <triggerMarker node="playerTriggerMarker" filename="$data/shared/assets/marker/markerIconLoad.i3d"   adjustToGround="true" />
        <triggerMarker node="objectTriggerMarker" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true" />
    </triggerMarkers>

    <hotspots>
        <hotspot type="LOADING" />
    </hotspots>

    <infoTrigger triggerNode="infoTrigger"/>

    <objectStorage capacity="1000" supportsBales="true" supportsPallets="true" maxLength="8.5" maxWidth="6" maxHeight="3.5">
        <playerTrigger node="playerTrigger" />
        <objectTrigger node="objectTrigger" />
        <spawnAreas>
            <spawnArea startNode="spawnArea1Start" endNode="spawnArea1End"/>
        </spawnAreas>
        <storageAreas>
            <storageArea startNode="storageArea1Start" endNode="storageArea1End"/>
        </storageAreas>
    </objectStorage>

    <pointOfInterest>
        <point triggerNode="objectTrigger" text="$l10n_poi_objectStorageUnload" showOwner="true"  showEveryone="false"/>
        <point triggerNode="playerTrigger" text="$l10n_poi_objectStorageLoad"   showOwner="true"  showEveryone="false" />
    </pointOfInterest>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
        </updateAreas>
        <obstacles>
            <obstacle node="slidingDoor1" size="1 4 7" >
                <animatedObject index="1" startTime="0" endTime="0.95" />
            </obstacle>
            <obstacle node="slidingDoor2" size="1 4 7" >
                <animatedObject index="2" startTime="0" endTime="0.95" />
            </obstacle>
        </obstacles>
    </ai>

    <dynamicallyLoadedParts>
    </dynamicallyLoadedParts>

    <lights>
    </lights>

    <animatedObjects>
        <animatedObject saveId="slidingDoor1" >
            <animation duration="3.5">
                <part node="slidingDoor1">
                    <keyFrame time="0.0" translation="0 0 0"/>
                    <keyFrame time="1.0" translation="0 0 -5.4"/>
                </part>
            </animation>
            <controls triggerNode="slidingDoor1Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="slidingDoor1Sound" template="slidingGateWoodLoop" />
                <posEnd linkNode="slidingDoor1Sound" template="woodDoorOpen" />
                <negEnd linkNode="slidingDoor1Sound" template="woodDoorClose" />
            </sounds>
        </animatedObject>
        <animatedObject saveId="slidingDoor2">
            <animation duration="3.5">
                <part node="slidingDoor2">
                    <keyFrame time="0.0" translation="0 0 0"/>
                    <keyFrame time="1.0" translation="0 0 -5.4"/>
                </part>
            </animation>
            <controls triggerNode="slidingDoor2Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="slidingDoor2Sound" template="slidingGateWoodLoop" />
                <posEnd linkNode="slidingDoor2Sound" template="woodDoorOpen" />
                <negEnd linkNode="slidingDoor2Sound" template="woodDoorClose" />
            </sounds>
        </animatedObject>
        <animatedObject saveId="door1">
            <animation duration="1.0">
                <part node="door1">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 110 0"/>
                </part>
                <part node="door2">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="0.8" rotation="0 -110 0"/>
                </part>
            </animation>
            <controls triggerNode="door1Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
            <sounds >
                <moving linkNode="door1Sound" template="metalDoorsLoop" />
                <posEnd linkNode="door1Sound" template="metalDoorsOpen" />
                <negEnd linkNode="door1Sound" template="metalDoorCloseRandom" />
            </sounds>
        </animatedObject>
    </animatedObjects>

    <solarPanels>
    </solarPanels>

    <i3dMappings>
        <i3dMapping id="clearAreaStart01" node="0>0|0" />
        <i3dMapping id="clearAreaWidth01" node="0>0|0|0" />
        <i3dMapping id="clearAreaHeight01" node="0>0|0|1" />
        <i3dMapping id="levelAreaStart01" node="0>1|0" />
        <i3dMapping id="levelAreaWidth01" node="0>1|0|0" />
        <i3dMapping id="levelAreaHeight01" node="0>1|0|1" />
        <i3dMapping id="indoorAreaStart01" node="0>2|0" />
        <i3dMapping id="indoorAreaWidth01" node="0>2|0|0" />
        <i3dMapping id="indoorAreaHeight01" node="0>2|0|1" />
        <i3dMapping id="testAreaStart01" node="0>3|0" />
        <i3dMapping id="testAreaEnd01" node="0>3|0|0" />
        <i3dMapping id="tipOcclusionUpdateAreaStart01" node="0>4|0" />
        <i3dMapping id="tipOcclusionUpdateAreaEnd01" node="0>4|0|0" />
        <i3dMapping id="slidingDoor1" node="0>5|0|0" />
        <i3dMapping id="slidingDoor1Trigger" node="0>5|0|1" />
        <i3dMapping id="slidingDoor1Sound" node="0>5|0|2" />
        <i3dMapping id="slidingDoor2" node="0>5|1|0" />
        <i3dMapping id="slidingDoor2Trigger" node="0>5|1|1" />
        <i3dMapping id="slidingDoor2Sound" node="0>5|1|2" />
        <i3dMapping id="door1" node="0>5|2|0" />
        <i3dMapping id="door2" node="0>5|2|1" />
        <i3dMapping id="door1Trigger" node="0>5|2|2" />
        <i3dMapping id="door1Sound" node="0>5|2|3" />
        <i3dMapping id="spawnArea1Start" node="0>7|0|0" />
        <i3dMapping id="spawnArea1End" node="0>7|0|0|0" />
        <i3dMapping id="storageArea1Start" node="0>7|0|1" />
        <i3dMapping id="storageArea1End" node="0>7|0|1|0" />
        <i3dMapping id="objectTrigger" node="0>7|1" />
        <i3dMapping id="objectTriggerMarker" node="0>7|1|0" />
        <i3dMapping id="warningStripes" node="0>7|1|0|0" />
        <i3dMapping id="playerTrigger" node="0>7|2" />
        <i3dMapping id="playerTriggerMarker" node="0>7|2|0" />
        <i3dMapping id="infoTrigger" node="0>7|3" />
    </i3dMappings>
</placeable>
