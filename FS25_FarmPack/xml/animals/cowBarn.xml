    <storeData>
        <name>$l10n_storeItem_cowBarnOld</name>
        <image>storeIcon/store_cowBarn.png</image>
        <price>185000</price>
        <functions>
            <function>$l10n_function_animalPenCow</function>
            <function>$l10n_function_adjustableMeadow</function>
        </functions>
        <lifetime>1000</lifetime>
        <dailyUpkeep>45</dailyUpkeep>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>animalpens</category>
        <brush>
            <type>husbandry</type>
            <category>animals</category>
            <tab>cows</tab>
        </brush>

        <storeIconRendering>
            <settings cameraXRot="-20" cameraYRot="50" advancedBoundingBox="true"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>1086208</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>194560</indexBufferMemoryUsage>
        <textureMemoryUsage>6881280</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>i3d/animals/cowBarn.i3d</filename>
        <boughtWithFarmland>true</boughtWithFarmland>
        <canBeRenamed>true</canBeRenamed>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testArea1Start" endNode="testArea1End" />
        </testAreas>

        <sounds>
            <place template="medImp" />
            <placeLayered template="cowLayer" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearArea1Start" widthNode="clearArea1Width" heightNode="clearArea1Height"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="10" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelArea1Start" widthNode="levelArea1Width" heightNode="levelArea1Height" groundType="asphalt"/>
        </levelAreas>
    </leveling>

    <foliageAreas>
    </foliageAreas>

    <indoorAreas>
        <indoorArea startNode="indoorArea1Start" widthNode="indoorArea1Width" heightNode="indoorArea1Height"/>
    </indoorAreas>

    <triggerMarkers>
        <triggerMarker node="markerMilk"         filename="$data/shared/assets/marker/markerIconMilk.i3d" />
        <triggerMarker node="markerFood"         filename="$data/shared/assets/marker/markerIconFood.i3d" />
        <triggerMarker node="markerAnimals"      filename="$data/shared/assets/marker/markerIconAnimals.i3d" />
        <triggerMarker node="markerLiquidManure" filename="$data/shared/assets/marker/markerIconSlurry.i3d" />
    </triggerMarkers>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
        </updateAreas>
    </ai>

    <hotspots>
        <hotspot type="COW" teleportNode="teleportNode" />
    </hotspots>

    <animatedObjects>
        <animatedObject saveId="slideDoor0" >
            <animation duration="1.5">
                <part node="slideDoor0">
                    <keyFrame time="0.0" translation="0 0 0"/>
                    <keyFrame time="1.0" translation="0 0 -4.213"/>
                </part>
            </animation>
            <controls triggerNode="slideDoorTrigger0" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="slideDoorBase0" template="slidingGateWoodLoop" volumeScale="0.6" />
                <posEnd linkNode="slideDoorBase0" template="woodDoorOpen" />
                <negEnd linkNode="slideDoorBase0" template="woodDoorClose" />
            </sounds>
        </animatedObject>
        <animatedObject saveId="slideDoor1" >
            <animation duration="1.5">
                <part node="slideDoor1">
                    <keyFrame time="0.0" translation="0 0 0"/>
                    <keyFrame time="1.0" translation="0 0 -4.213"/>
                </part>
            </animation>
            <controls triggerNode="slideDoorTrigger1" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="slideDoorBase1" template="slidingGateWoodLoop" volumeScale="0.6" />
                <posEnd linkNode="slideDoorBase1" template="woodDoorOpen" />
                <negEnd linkNode="slideDoorBase1" template="woodDoorClose" />
            </sounds>
        </animatedObject>
        <animatedObject saveId="slideDoor2" >
            <animation duration="1.5">
                <part node="slideDoor2">
                    <keyFrame time="0.0" translation="0 0 0"/>
                    <keyFrame time="1.0" translation="4.814 0 0"/>
                </part>
            </animation>
            <controls triggerNode="slideDoorTrigger2" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="slideDoorBase2" template="slidingGateWoodLoop" volumeScale="0.6" />
                <posEnd linkNode="slideDoorBase2" template="woodDoorOpen" />
                <negEnd linkNode="slideDoorBase2" template="woodDoorClose" />
            </sounds>
        </animatedObject>
    </animatedObjects>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart node="0" linkNode="lightSwitch" filename="$data/shared/assets/lights/terraLed/switch.i3d" />
        <dynamicallyLoadedPart node="0" linkNode="milkContainer1" filename="$data/placeables/lely/nautilus/nautilus.i3d"/>
        <dynamicallyLoadedPart node="0" linkNode="milkContainer2" filename="$data/placeables/lely/nautilus/nautilus.i3d"/>
