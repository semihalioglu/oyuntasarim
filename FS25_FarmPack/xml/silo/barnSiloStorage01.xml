<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="silo" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_storeItem_barnSilo01</name>
        <functions>
            <function>$l10n_function_garage</function>
            <function>$l10n_function_farmSilo</function>
        </functions>
        <image>storeIcon/store_barnOld01.dds</image>
        <price>89000</price>
        <dailyUpkeep>80</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>silos</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>silos</tab>
        </brush>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
        <vertexBufferMemoryUsage>405504</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>80896</indexBufferMemoryUsage>
        <textureMemoryUsage>5898240</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>i3d/silo/barnSilo01.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <testAreas>
            <testArea startNode="testAreaStart01" endNode="testAreaEnd01" />
        </testAreas>
        <sounds>
            <place template="medImp" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart01" widthNode="clearAreaWidth01" heightNode="clearAreaHeight01"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart01" widthNode="levelAreaWidth01" heightNode="levelAreaHeight01" groundType="asphalt"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart01" widthNode="indoorAreaWidth01" heightNode="indoorAreaHeight01"/>
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
        </updateAreas>
        <obstacles>
            <obstacle node="slidingDoor1" size="1 4 7" >
                <animatedObject index="1" startTime="0" endTime="0.95" />
            </obstacle>
            <obstacle node="slidingDoor2" size="1 4 7" >
                <animatedObject index="2" startTime="0" endTime="0.95" />
            </obstacle>
        </obstacles>
        <splines>
            <spline node="aiSpline" />
        </splines>
    </ai>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart filename="$data/placeables/shared/sellingStationGeneric/sellingStationGenericNoCover.i3d" node="0" linkNode="grainGutterLinkNode" />
    </dynamicallyLoadedParts>

    <infoTrigger triggerNode="infoTrigger"/>

    <silo>
        <loadingStation node="loadingTrigger" supportsExtension="true" storageRadius="50">
            <loadTrigger triggerNode="loadingTrigger" fillLitersPerSecond="2000" dischargeNode="dischargeNode" fillTypeCategories="farmSilo" aiNode="aiLoadingNode">
                <effectNode effectClass="PipeEffect" effectNode="pipeEffect"      materialType="pipe"           fadeTime="0.5" maxBending="0" controlPoint="4.8 0 0 0"/>
                <effectNode                          effectNode="pipeEffectSmoke" materialType="unloadingSmoke" fadeTime="0.5" />
                <sounds>
                    <loading template="silosActive" />
                </sounds>
            </loadTrigger>
        </loadingStation>

        <unloadingStation supportsExtension="true" storageRadius="50">
            <unloadTrigger exactFillRootNode="exactFillRootNode" fillTypeCategories="farmSilo" aiNode="aiUnloadingNode"/>
        </unloadingStation>

        <storages>
            <storage node="storage" fillTypeCategories="farmSilo" capacity="300000" isExtension="true"/>
        </storages>
    </silo>

    <hotspots>
        <hotspot type="UNLOADING" linkNode="mapPosition" teleportNode="teleportNode"/>
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="markerLoading"   filename="$data/shared/assets/marker/markerIconLoad.i3d" />
        <triggerMarker node="markerUnloading" filename="$data/shared/assets/marker/markerIconUnload.i3d" />
    </triggerMarkers>

    <lights>
    </lights>

    <animatedObjects>
        <animatedObject saveId="slidingDoor1" >
            <animation duration="3.5">
                <part node="slidingDoor1">
                    <keyFrame time="0.0" translation="0 0 0"/>
                    <keyFrame time="1.0" translation="0 0 -4.4"/>
                </part>
            </animation>
            <controls triggerNode="slidingDoor1Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="slidingDoor1Sound" template="slidingGateWoodLoop" />
                <posEnd linkNode="slidingDoor1Sound" template="woodDoorOpen" />
                <negEnd linkNode="slidingDoor1Sound" template="woodDoorClose" />
            </sounds>
        </animatedObject>
        <animatedObject saveId="slidingDoor2">
            <animation duration="3.5">
                <part node="slidingDoor2">
                    <keyFrame time="0.0" translation="0 0 0"/>
                    <keyFrame time="1.0" translation="0 0 -4.4"/>
                </part>
            </animation>
            <controls triggerNode="slidingDoor2Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="slidingDoor2Sound" template="slidingGateWoodLoop" />
                <posEnd linkNode="slidingDoor2Sound" template="woodDoorOpen" />
                <negEnd linkNode="slidingDoor2Sound" template="woodDoorClose" />
            </sounds>
        </animatedObject>
    </animatedObjects>

    <solarPanels>
    </solarPanels>

    <i3dMappings>
        <i3dMapping id="clearAreaStart01" node="0>0|0" />
        <i3dMapping id="clearAreaWidth01" node="0>0|0|0" />
        <i3dMapping id="clearAreaHeight01" node="0>0|0|1" />
        <i3dMapping id="levelAreaStart01" node="0>1|0" />
        <i3dMapping id="levelAreaWidth01" node="0>1|0|0" />
        <i3dMapping id="levelAreaHeight01" node="0>1|0|1" />
        <i3dMapping id="indoorAreaStart01" node="0>2|0" />
        <i3dMapping id="indoorAreaWidth01" node="0>2|0|0" />
        <i3dMapping id="indoorAreaHeight01" node="0>2|0|1" />
        <i3dMapping id="testAreaStart01" node="0>3|0" />
        <i3dMapping id="testAreaEnd01" node="0>3|0|0" />
        <i3dMapping id="tipOcclusionUpdateAreaStart01" node="0>4|0" />
        <i3dMapping id="tipOcclusionUpdateAreaEnd01" node="0>4|0|0" />
        <i3dMapping id="slidingDoor1" node="0>5|0|0" />
        <i3dMapping id="slidingDoor1Trigger" node="0>5|0|1" />
        <i3dMapping id="slidingDoor1Sound" node="0>5|0|2" />
        <i3dMapping id="slidingDoor2" node="0>5|1|0" />
        <i3dMapping id="slidingDoor2Trigger" node="0>5|1|1" />
        <i3dMapping id="slidingDoor2Sound" node="0>5|1|2" />
        <i3dMapping id="aiUpdateAreaStart01" node="0>7|0" />
        <i3dMapping id="aiUpdateAreaEnd01" node="0>7|0|0" />
        <i3dMapping id="loadingTrigger" node="0>8|0|0|0" />
        <i3dMapping id="dischargeNode" node="0>8|0|0|1" />
        <i3dMapping id="dischargeEffect" node="0>8|0|0|2" />
        <i3dMapping id="pipeEffect" node="0>8|0|0|2|0" />
        <i3dMapping id="pipeEffectSmoke" node="0>8|0|0|2|1" />
        <i3dMapping id="aiLoadingNode" node="0>8|0|0|3" />
        <i3dMapping id="exactFillRootNode" node="0>8|1|0" />
        <i3dMapping id="grainGutterLinkNode" node="0>8|1|1" />
        <i3dMapping id="aiUnloadingNode" node="0>8|1|2" />
        <i3dMapping id="mapPosition" node="0>8|2" />
        <i3dMapping id="storage" node="0>8|3" />
        <i3dMapping id="infoTrigger" node="0>8|4" />
        <i3dMapping id="aiSpline" node="0>8|5" />
        <i3dMapping id="markerLoading" node="0>8|6" />
        <i3dMapping id="markerUnloading" node="0>8|7" />
        <i3dMapping id="teleportNode" node="0>8|8" />
    </i3dMappings>
</placeable>
