<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="objectStorage" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_storeItem_barnOld02</name>
        <functions>
            <function>$l10n_function_garage</function>
            <function>$l10n_function_objectStorageBarn</function>
        </functions>
        <image>storeIcon/store_barnOld02.dds</image>
        <price>38000</price>
        <dailyUpkeep>10</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>storages</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>silos</tab>
        </brush>
        <vertexBufferMemoryUsage>488192</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>88576</indexBufferMemoryUsage>
        <textureMemoryUsage>5767168</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>i3d/barn/barnOld02.i3d</filename>
        <boughtWithFarmland>true</boughtWithFarmland>
        <canBeRenamed>true</canBeRenamed>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <testAreas>
            <testArea startNode="testAreaStart01" endNode="testAreaEnd01" />
        </testAreas>
        <sounds>
            <place template="medImp" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart01" widthNode="clearAreaWidth01" heightNode="clearAreaHeight01"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart01" widthNode="levelAreaWidth01" heightNode="levelAreaHeight01" groundType="asphalt"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart01" widthNode="indoorAreaWidth01" heightNode="indoorAreaHeight01"/>
    </indoorAreas>

    <triggerMarkers>
        <triggerMarker node="warningStripes" />
        <triggerMarker node="playerTriggerMarker" filename="$data/shared/assets/marker/markerIconLoad.i3d"   adjustToGround="false" />
        <triggerMarker node="objectTriggerMarker" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="false" />
    </triggerMarkers>

    <hotspots>
        <hotspot type="LOADING" />
    </hotspots>

    <infoTrigger triggerNode="infoTrigger"/>

    <objectStorage capacity="1000" supportsBales="true" supportsPallets="false" maxLength="8.5" maxWidth="6" maxHeight="3.5">
        <playerTrigger node="playerTrigger" />
        <objectTrigger node="objectTrigger" />
        <spawnAreas>
            <spawnArea startNode="spawnArea1Start" endNode="spawnArea1End"/>
        </spawnAreas>
        <storageAreas>
            <storageArea startNode="storageArea1Start" endNode="storageArea1End"/>
            <storageArea startNode="storageArea2Start" endNode="storageArea2End"/>
            <storageArea startNode="storageArea3Start" endNode="storageArea3End"/>
        </storageAreas>
    </objectStorage>

    <pointOfInterest>
        <point triggerNode="objectTrigger" text="$l10n_poi_objectStorageUnload" showOwner="true"  showEveryone="false"/>
        <point triggerNode="playerTrigger" text="$l10n_poi_objectStorageLoad"   showOwner="true"  showEveryone="false" />
    </pointOfInterest>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
        </updateAreas>
    </ai>

    <dynamicallyLoadedParts>
    </dynamicallyLoadedParts>

    <lights>
    </lights>

